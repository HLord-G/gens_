{
    "manifest_version": 3,
    "name": "regs",
    "version": "7.0",
    "description": "Simple Chrome extension with content script",
    "author": "Lordskey",
  
    "action": {
      "default_popup": "popup.html",
      "default_icon": "assets/icon.png"
    },
  
    "background": {
      "service_worker": "background.js"
    },

  "web_accessible_resources": [
    {
      "resources": ["usernames.json","user_images/*"],
      "matches": [
        "https://www.tumblr.com/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ]
    }
  ],
  
    "permissions": [
      "storage",
      "activeTab",
      "scripting"
    ],

    
  
    "content_scripts": [
      {
        "matches": [
          "https://www.tumblr.com/*",
          "http://localhost/*",
          "http://127.0.0.1/*"
        ],
        "js":   ["/assets/libs/q.js","content.js"],
        "css":  ["/assets/owl_style.css"],
        "resources": ["usernames.json"]
      }
    ]
  }